<div class="container">
    <h2>Carrito de Compras: {{cart._id}}</h2>
    
    {{#if cart.products.length}}
        <table class="products-table">
            <thead>
                <tr>
                    <th>Producto</th>
                    <th>Precio Unitario</th>
                    <th>Cantidad</th>
                </tr>
            </thead>
            <tbody>
                {{#each cart.products}}
                <tr>
                    <td>{{this.product.title}}</td>
                    <td>${{this.product.price}}</td>
                    <td>{{this.quantity}}</td>
                </tr>
                {{/each}}
            </tbody>
        </table>
        
        <div class="actions">
            <button onclick="emptyCart('{{cart._id}}')" class="btn-danger">Vaciar Carrito</button>
        </div>
    {{else}}
        <p class="no-products">Tu carrito está vacío.</p>
    {{/if}}
    
    <div class="actions">
        <a href="/products" class="btn">Seguir Comprando</a>
    </div>
</div>

<script>
async function emptyCart(cartId) {
    if(confirm('¿Estás seguro que deseas vaciar el carrito?')) {
        try {
            const response = await fetch(`/api/carts/${cartId}`, {
                method: 'DELETE',
            });
            
            if(response.ok) {
                alert('Carrito vaciado exitosamente');
                location.reload();
            } else {
                console.error('Error al vaciar el carrito');
            }
        } catch (error) {
            console.error('Error de red al vaciar carrito:', error);
        }
    }
}
</script>

<div class="container">
    <h2>Lista de Productos</h2>
    
    {{#if products.length}}
        <table class="products-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nombre</th>
                    <th>Descripción</th>
                    <th>Precio</th>
                    <th>Stock</th>
                </tr>
            </thead>
            <tbody>
                {{#each products}}
                <tr>
                    <td>{{this.id}}</td>
                    <td>{{this.title}}</td>
                    <td>{{this.description}}</td>
                    <td>${{this.price}}</td>
                    <td>{{this.stock}}</td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    {{else}}
        <p class="no-products">No hay productos disponibles.</p>
    {{/if}}
    
    <div class="actions">
        <a href="/realtimeproducts" class="btn">Ver Productos en Tiempo Real</a>
    </div>
</div>
